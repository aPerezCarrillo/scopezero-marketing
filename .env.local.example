# ── Sanity CMS ──────────────────────────────────────────────────────────────
# Create a free project at sanity.io, then copy the projectId here
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ── Contact form (Resend) ────────────────────────────────────────────────────
# Same API key you already use in the app — reuse it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# "From" address — must be on a domain verified in your Resend account.
# If you already send from @scopezer0.com in the app, the domain is already verified.
RESEND_FROM=website@scopezer0.com

# "To" address — where form submissions land (your real Google Workspace inbox)
CONTACT_EMAIL_TO=you@scopezer0.com

# ── External links ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://carbon-accounting.scopezer0.com
NEXT_PUBLIC_DEMO_URL=https://scopezero-consultant.base44.app
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
